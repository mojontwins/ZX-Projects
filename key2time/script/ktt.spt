###############

LEVELID LEVEL_6
INC_DECORATIONS decos6.spt

ENTERING GAME
	IF TRUE
	THEN
		SET $EPOCA = 6
		SETXY 4, 6
	END
END

PRESS_FIRE AT SCREEN 0
	# BACK TO THE T.A.R.D.I.S
	IF PLAYER_TOUCHES 4, 6
	THEN
