# --------------------------------------------------------------------------- #

##########################
### LEVEL T.A.R.D.I.S. ###
##########################

LEVELID LEVEL_TARDIS
INC_DECORATIONS decosT.spt

ENTERING GAME
	IF TRUE
	THEN
		SETXY 7, 3
	END
END

ENTERING SCREEN 0
	IF $FIRST_TIME_LEVEL_T = 1
	THEN
		SET_FIRE_ZONE_TILES 6, 2, 8, 4
	END

	IF $FIRST_TIME_LEVEL_T = 0
	THEN
		SET_FIRE_ZONE_TILES 7, 0, 7, 0
	END
END

PRESS_FIRE AT SCREEN 0
	IF $FIRST_TIME_LEVEL_T = 1
	THEN
		SET $FIRST_TIME_LEVEL_T = 0
		SET_FIRE_ZONE_TILES 7, 0, 7, 1
		EXTERN_E 0, 5
		%CONV_END
		REDRAW
	END

	IF PLAYER_TOUCHES 7, 1
	THEN
		%CLS
		WARP_TO_LEVEL #$EPOCA, 0, 0, 0, 1
	END

	# Tardis.
	IF PLAYER_IN_X_TILES 6, 8
	IF PLAYER_IN_Y_TILES 5, 7
	IF $FIRST_TIME_TARDIS = 1
	THEN
		SET $FIRST_TIME_TARDIS = 0
		EXTERN_E 0, 7
		EXTERN_E 0, 8
		EXTERN_E 0, 9
		EXTERN_E 0, 10
		%CONV_END
		REDRAW
	END
	
	IF PLAYER_IN_X_TILES 6, 8
	IF PLAYER_IN_Y_TILES 5, 7
	THEN
		%CLS
		%TARDIS_MENU
		%CLS
		REDRAW
		SHOW
		%EFFECT
		%SHOW_TIME
		REDRAW
	END
END

ENTERING SCREEN 4
	IF TRUE
	THEN
		ADD_CONTAINER $CONT_TEST, 10, 6
	END
END

PRESS_FIRE AT SCREEN 4
	IF PLAYER_TOUCHES 4, 7
	THEN
		EXTERN_E 0, 4
		EXTERN_E 0, 6
		%CONV_END
		REDRAW
	END

	IF PLAYER_IN_Y_TILES 6, 7
	IF PLAYER_IN_X_TILES 6, 8
	THEN
		DECORATIONS
			6, 5, 26
			7, 5, 27
			8, 5, 28
			6, 6, 29
			7, 6, 30
			8, 6, 31
		END
		SHOW
		PAUSE 20
		%SHOW_ARCON
		DECORATIONS
			6, 5, 20
			7, 5, 21
			8, 5, 22
			6, 6, 23
			7, 6, 24
			8, 6, 25
		END
		REDRAW
	END
END

END_OF_LEVEL
